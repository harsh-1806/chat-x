        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="01 - Connect &amp; Authenticate" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import java.net.Socket
import java.nio.ByteBuffer
import java.nio.charset.StandardCharsets

def host = vars.get(&quot;SERVER_HOST&quot;)
def port = vars.get(&quot;SERVER_PORT&quot;) as int
def username = vars.get(&quot;username&quot;)
def password = vars.get(&quot;password&quot;)

// Helper: encode a JSON string as a length-prefixed frame
def encodeFrame(String json) {
    byte[] payload = json.getBytes(StandardCharsets.UTF_8)
    ByteBuffer buf = ByteBuffer.allocate(4 + payload.length)
    buf.putInt(payload.length)
    buf.put(payload)
    return buf.array()
}

// Helper: read a length-prefixed frame and return the JSON string
def readFrame(InputStream inputStream) {
    byte[] header = new byte[4]
    int totalRead = 0
    while (totalRead &lt; 4) {
        int n = inputStream.read(header, totalRead, 4 - totalRead)
        if (n == -1) throw new IOException(&quot;Connection closed while reading header&quot;)
        totalRead += n
    }
    int length = ByteBuffer.wrap(header).getInt()
    if (length &lt;= 0 || length &gt; 65536) throw new IOException(&quot;Invalid frame length: &quot; + length)

    byte[] payload = new byte[length]
    totalRead = 0
    while (totalRead &lt; length) {
        int n = inputStream.read(payload, totalRead, length - totalRead)
        if (n == -1) throw new IOException(&quot;Connection closed while reading payload&quot;)
        totalRead += n
    }
    return new String(payload, StandardCharsets.UTF_8)
}

try {
    // Open TCP connection
    Socket socket = new Socket(host, port)
    socket.setSoTimeout(10000)  // 10s read timeout
    socket.setTcpNoDelay(true)

    def out = socket.getOutputStream()
    def inStream = socket.getInputStream()

    // Store socket for later samplers
    vars.putObject(&quot;tcp_socket&quot;, socket)
    vars.putObject(&quot;tcp_out&quot;, out)
    vars.putObject(&quot;tcp_in&quot;, inStream)

    // Build AUTH_REQUEST JSON
    long ts = System.currentTimeMillis()
    String authJson = &quot;&quot;&quot;{&quot;type&quot;:&quot;AUTH_REQUEST&quot;,&quot;sender&quot;:&quot;${username}&quot;,&quot;content&quot;:&quot;${password}&quot;,&quot;timestamp&quot;:${ts}}&quot;&quot;&quot;

    // Send AUTH_REQUEST
    out.write(encodeFrame(authJson))
    out.flush()

    // Read AUTH_RESPONSE
    String response = readFrame(inStream)
    vars.put(&quot;auth_response&quot;, response)

    // Check success
    if (response.contains(&apos;&quot;success&quot;:true&apos;)) {
        // Extract sessionId
        def matcher = (response =~ /&quot;sessionId&quot;:&quot;([^&quot;]+)&quot;/)
        if (matcher.find()) {
            vars.put(&quot;sessionId&quot;, matcher.group(1))
        }
        SampleResult.setResponseData(response, &quot;UTF-8&quot;)
        SampleResult.setResponseCode(&quot;200&quot;)
        SampleResult.setResponseMessage(&quot;AUTH_SUCCESS&quot;)
        SampleResult.setSuccessful(true)
    } else {
        SampleResult.setResponseData(response, &quot;UTF-8&quot;)
        SampleResult.setResponseCode(&quot;401&quot;)
        SampleResult.setResponseMessage(&quot;AUTH_FAILED&quot;)
        SampleResult.setSuccessful(false)
    }

    // Read the auto-join SYSTEM message for default room (if any)
    try {
        socket.setSoTimeout(2000)
        String systemMsg = readFrame(inStream)
        vars.put(&quot;system_join_msg&quot;, systemMsg)
        // There might also be a HISTORY_RESPONSE, try to read it
        try {
            String historyMsg = readFrame(inStream)
            vars.put(&quot;auto_history&quot;, historyMsg)
        } catch (Exception ignore) {}
    } catch (Exception ignore) {}

    socket.setSoTimeout(10000)  // Reset timeout

} catch (Exception e) {
    SampleResult.setResponseData(&quot;Connection failed: &quot; + e.getMessage(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;500&quot;)
    SampleResult.setResponseMessage(&quot;ERROR&quot;)
    SampleResult.setSuccessful(false)
    log.error(&quot;Auth failed for &quot; + username, e)
}
</stringProp>
        </JSR223Sampler>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Auth Success" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="-538673239">success&quot;:true</stringProp>
            </collectionProp>
            <stringProp name="Assertion.custom_message">Authentication should succeed</stringProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
          </ResponseAssertion>
