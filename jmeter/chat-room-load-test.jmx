          <stringProp name="script">
import java.nio.ByteBuffer
import java.nio.charset.StandardCharsets

def encodeFrame(String json) {
    byte[] payload = json.getBytes(StandardCharsets.UTF_8)
    ByteBuffer buf = ByteBuffer.allocate(4 + payload.length)
    buf.putInt(payload.length)
    buf.put(payload)
    return buf.array()
}

def readFrame(InputStream inputStream) {
    byte[] header = new byte[4]
    int totalRead = 0
    while (totalRead &lt; 4) {
        int n = inputStream.read(header, totalRead, 4 - totalRead)
        if (n == -1) throw new IOException(&quot;Connection closed&quot;)
        totalRead += n
    }
    int length = ByteBuffer.wrap(header).getInt()
    byte[] payload = new byte[length]
    totalRead = 0
    while (totalRead &lt; length) {
        int n = inputStream.read(payload, totalRead, length - totalRead)
        if (n == -1) throw new IOException(&quot;Connection closed&quot;)
        totalRead += n
    }
    return new String(payload, StandardCharsets.UTF_8)
}

try {
    def out = vars.getObject(&quot;tcp_out&quot;)
    def inStream = vars.getObject(&quot;tcp_in&quot;)
    def testRoom = vars.get(&quot;TEST_ROOM&quot;)

    long ts = System.currentTimeMillis()
    String joinJson = &quot;&quot;&quot;{&quot;type&quot;:&quot;JOIN&quot;,&quot;room&quot;:&quot;${testRoom}&quot;,&quot;timestamp&quot;:${ts}}&quot;&quot;&quot;

    out.write(encodeFrame(joinJson))
    out.flush()

    // Read the SYSTEM acknowledgement
    def socket = vars.getObject(&quot;tcp_socket&quot;)
    socket.setSoTimeout(5000)
    String response = readFrame(inStream)
    socket.setSoTimeout(10000)

    SampleResult.setResponseData(response, &quot;UTF-8&quot;)
    if (response.contains(&apos;&quot;type&quot;:&quot;SYSTEM&quot;&apos;) || response.contains(&quot;joined&quot;)) {
        SampleResult.setResponseCode(&quot;200&quot;)
        SampleResult.setResponseMessage(&quot;JOIN_SUCCESS&quot;)
        SampleResult.setSuccessful(true)
    } else {
        SampleResult.setResponseCode(&quot;200&quot;)
        SampleResult.setResponseMessage(&quot;JOIN_RESPONSE&quot;)
        SampleResult.setSuccessful(true)
    }

    // There might be a HISTORY_RESPONSE too, try to drain it
    try {
        socket.setSoTimeout(1000)
        String histMsg = readFrame(inStream)
        vars.put(&quot;join_history&quot;, histMsg)
    } catch (Exception ignore) {}
    socket.setSoTimeout(10000)

} catch (Exception e) {
    SampleResult.setResponseData(&quot;Join failed: &quot; + e.getMessage(), &quot;UTF-8&quot;)
    SampleResult.setResponseCode(&quot;500&quot;)
    SampleResult.setResponseMessage(&quot;ERROR&quot;)
    SampleResult.setSuccessful(false)
    log.error(&quot;Join room failed&quot;, e)
}
</stringProp>
